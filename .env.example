# ============================================================
# WhatsApp Repair Bot - Environment Configuration
# Copy this file to .env and fill in your actual values
# ============================================================

# ---- AI Provider (choose one: 'groq' | 'claude' | 'openai') --------
AI_PROVIDER=groq

# ---- Groq API (FREE - https://console.groq.com) ------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Claude API (Anthropic) --------------------------------
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ---- OpenAI API (alternative) ------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ---- Google Sheets -----------------------------------------
# Path to your service account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./config/google-service-account.json
# Google Sheet ID (from the URL: /spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=your_google_sheet_id_here
# Tab name inside the spreadsheet
GOOGLE_SHEET_TAB=Leads

# ---- Owner Notification ------------------------------------
# WhatsApp number of the shop owner (international format, no + sign)
OWNER_PHONE=919876543210

# ---- Business Info -----------------------------------------
BUSINESS_NAME=Tech Fix Pro
BUSINESS_CITY=Mumbai

# ---- App Config --------------------------------------------
PORT=3000
NODE_ENV=development

# ---- Session Storage ---------------------------------------
# Folder where WhatsApp session data is saved (for persistence)
SESSION_DATA_PATH=./.wwebjs_auth
